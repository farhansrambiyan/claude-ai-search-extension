{
    "manifest_version": 3,
    "name": "Claude AI Search",
    "version": "1.0.0",
    "description": "Upgrade your default search engine to Claude AI.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Claude AI Search"
    },
    "background": {
        "service_worker": "background.js"
    },
    "chrome_settings_overrides": {
        "search_provider": {
            "name": "Claude AI",
            "keyword": "claude",
            "favicon_url": "https://claude.ai/favicon.ico",
            "search_url": "https://claude.ai/new?q={searchTerms}",
            "encoding": "UTF-8",
            "is_default": true
        }
    },
    "content_scripts": [
        {
            "matches": ["https://claude.ai/new*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": ["https://claude.ai/*"],
    "permissions": ["storage", "declarativeNetRequest", "contextMenus"],
    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "bypass_rules",
                "enabled": false,
                "path": "rules.json"
            }
        ]
    }
}